# ══════════════════════════════════════════════════════════════════════════════
#  Nahla SaaS — Local development environment
#  Copy config/.env.example and fill in real values.
#  Never commit secrets to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=nahla
POSTGRES_PASSWORD=nahla123
POSTGRES_DB=nahla
DATABASE_URL=postgresql://nahla:nahla123@localhost:5432/nahla

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development

# ── AI — Anthropic Claude ─────────────────────────────────────────────────────
# Primary env var (standard Anthropic SDK name).
# Set to your Anthropic API key. Leave blank to run in rule-based fallback mode.
ANTHROPIC_API_KEY=
# Legacy alias — used if ANTHROPIC_API_KEY is not set
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-opus-4-6

# URL that whatsapp-service uses to reach the AI orchestrator
AI_ORCHESTRATOR_URL=http://localhost:8016/orchestrate

# ── AI Engine (stateless fallback, port 8002) ─────────────────────────────────
# Leave blank to use rule-based fallback
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
AI_ENGINE_URL=http://localhost:8002/ai/respond

# ── Backend JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=dev-local-jwt-secret-change-in-production
JWT_EXPIRE_HOURS=168

# ── Admin bootstrap credentials ───────────────────────────────────────────────
ADMIN_EMAIL=admin@nahlah.ai
ADMIN_PASSWORD=nahla-admin-2026

# ── Registration gate ─────────────────────────────────────────────────────────
# Set to "false" for local dev to allow direct registration without invite
REQUIRE_INVITE=false

# ── WhatsApp Cloud API ────────────────────────────────────────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v17.0
WHATSAPP_TOKEN=
PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=nahla_verify_token

# ── Email — Resend API ────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=نحلة <noreply@nahlah.ai>
DASHBOARD_URL=http://localhost:3000

# ── Salla Integration ─────────────────────────────────────────────────────────
SALLA_CLIENT_ID=
SALLA_CLIENT_SECRET=
SALLA_REDIRECT_URI=http://localhost:8000/oauth/salla/callback
SALLA_WEBHOOK_SECRET=

# ── Zid Integration ───────────────────────────────────────────────────────────
ZID_CLIENT_ID=
ZID_CLIENT_SECRET=
ZID_REDIRECT_URI=http://localhost:8000/integrations/zid/oauth/callback
ZID_WEBHOOK_SECRET=

# ── API secret (inter-service) ────────────────────────────────────────────────
API_SECRET_KEY=dev-api-secret-change-in-production

# ── Moyasar (payment gateway) ─────────────────────────────────────────────────
MOYASAR_API_KEY=
MOYASAR_SANDBOX=true

# ── Stripe (SaaS subscription billing) ───────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
STRIPE_TRIAL_DAYS=14

# ── HyperPay (Saudi local payments) ──────────────────────────────────────────
HYPERPAY_ACCESS_TOKEN=
HYPERPAY_ENTITY_ID=
HYPERPAY_WEBHOOK_SECRET=
HYPERPAY_LIVE_MODE=false

# ── Internal service URLs ─────────────────────────────────────────────────────
ORCHESTRATOR_URL=http://localhost:8016
ORDER_SERVICE_URL=http://localhost:8004
COUPON_SERVICE_URL=http://localhost:8005
CAMPAIGN_SERVICE_URL=http://localhost:8006
CONVERSATION_SERVICE_URL=http://localhost:8008
AUTOMATION_SERVICE_URL=http://localhost:8009
ANALYTICS_SERVICE_URL=http://localhost:8010
BILLING_SERVICE_URL=http://localhost:8011
LOCATION_SERVICE_URL=http://localhost:8012
MARKETPLACE_SERVICE_URL=http://localhost:8013
