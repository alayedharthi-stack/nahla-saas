# ══════════════════════════════════════════════════════════════════════════════
#  Nahla SaaS — Environment Variables Reference
#  Copy this file to .env at the repo root and fill in real values.
#  Never commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────────────────────────
# Used by: all services, alembic migrations
DATABASE_URL=postgresql://nahla:nahla_password@localhost:5432/nahla_saas

# ── Service Ports (for reference — set in each service's main.py) ────────────
# PORT_BACKEND=8000
# PORT_WHATSAPP=8001
# PORT_AI_ENGINE=8002
# PORT_CATALOG=8003
# PORT_ORDERS=8004
# PORT_COUPONS=8005
# PORT_CAMPAIGNS=8006
# PORT_WIDGET=8007
# PORT_CONVERSATIONS=8008
# PORT_AUTOMATION=8009
# PORT_ANALYTICS=8010
# PORT_BILLING=8011
# PORT_LOCATION=8012
# PORT_MARKETPLACE=8013
# PORT_SALLA_INTEGRATION=8014
# PORT_ZID_INTEGRATION=8015

# ── AI Orchestrator (Customer Intelligence Hub) ──────────────────────────────
# Used by: services/ai-orchestrator/
# The orchestrator is the primary AI entry point. whatsapp-service calls this
# first and falls back to ai-engine if this service is unavailable.
#
# ANTHROPIC_API_KEY is the standard variable read by the anthropic SDK and by
# services/ai-orchestrator/engine/claude_client.py.
# CLAUDE_API_KEY is a legacy alias kept for backwards compatibility — set either
# one; ANTHROPIC_API_KEY takes precedence when both are present.
# Leave both empty to run in rule-based fallback mode (dev/testing).
ANTHROPIC_API_KEY=
# CLAUDE_API_KEY=   # legacy alias — use ANTHROPIC_API_KEY instead
CLAUDE_MODEL=claude-opus-4-6

# Base URL of the AI Orchestrator service (used by both backend and whatsapp-service).
# Both services append /orchestrate when calling this service.
ORCHESTRATOR_URL=http://localhost:8016

# ── AI Engine (stateless fallback) ───────────────────────────────────────────
# Used by: ai-engine/main.py
# Fallback only — whatsapp-service calls this when the orchestrator is down.
# Leave OPENAI_API_KEY empty to run in rule-based fallback mode (dev/testing).
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# URL whatsapp-service uses to call the AI engine directly (fallback)
AI_ENGINE_URL=http://localhost:8002/ai/respond

# ── WhatsApp Cloud API ───────────────────────────────────────────────────────
# Used by: whatsapp-service
WHATSAPP_API_URL=https://graph.facebook.com/v17.0
WHATSAPP_TOKEN=your_whatsapp_business_token_here
WHATSAPP_VERIFY_TOKEN=nahla_verify_token

# ── Salla Integration ────────────────────────────────────────────────────────
# Used by: integrations/salla/
# Obtain from: https://salla.partners (Developer Console → Your App → OAuth)
SALLA_CLIENT_ID=your_salla_client_id
SALLA_CLIENT_SECRET=your_salla_client_secret
SALLA_REDIRECT_URI=https://api.nahlah.ai/oauth/salla/callback
SALLA_WEBHOOK_SECRET=your_salla_webhook_signing_secret

# ── Zid Integration ──────────────────────────────────────────────────────────
# Used by: integrations/zid/
# Obtain from: https://developers.zid.sa (App Dashboard → OAuth Settings)
ZID_CLIENT_ID=your_zid_client_id
ZID_CLIENT_SECRET=your_zid_client_secret
ZID_REDIRECT_URI=https://api.nahlah.ai/integrations/zid/oauth/callback
ZID_WEBHOOK_SECRET=your_zid_webhook_signing_secret

# ── Billing / Payments (Moyasar) ─────────────────────────────────────────────
# Used by: billing-service
# Obtain from: https://dashboard.moyasar.com → Settings → API Keys
MOYASAR_API_KEY=your_moyasar_api_key
MOYASAR_SANDBOX=true

# ── Internal service URLs (used for service-to-service calls) ────────────────
ORDER_SERVICE_URL=http://localhost:8004
COUPON_SERVICE_URL=http://localhost:8005
CAMPAIGN_SERVICE_URL=http://localhost:8006
CONVERSATION_SERVICE_URL=http://localhost:8008
AUTOMATION_SERVICE_URL=http://localhost:8009
ANALYTICS_SERVICE_URL=http://localhost:8010
BILLING_SERVICE_URL=http://localhost:8011
LOCATION_SERVICE_URL=http://localhost:8012
MARKETPLACE_SERVICE_URL=http://localhost:8013
