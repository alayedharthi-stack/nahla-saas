# ── Nahla SaaS — Dashboard (React + Vite) ─────────────────────────────────────
# Multi-stage build:
#   Stage 1 (builder): install deps + compile TypeScript + bundle with Vite
#   Stage 2 (runner):  serve the static bundle with nginx
# ──────────────────────────────────────────────────────────────────────────────

# ── Stage 1: build ────────────────────────────────────────────────────────────
FROM node:20-alpine AS builder

WORKDIR /app

# Vite reads VITE_* variables at build time, not at nginx runtime.
ARG VITE_API_BASE=http://localhost:8000
ARG VITE_API_URL=http://localhost:8000
ENV VITE_API_BASE=$VITE_API_BASE
ENV VITE_API_URL=$VITE_API_URL

# Install dependencies (separate layer for caching)
COPY package.json ./
RUN npm install

# Copy source and build
COPY . .
RUN npm run build

# ── Stage 2: serve ────────────────────────────────────────────────────────────
FROM nginx:1.25-alpine AS runner

# Remove default nginx static assets
RUN rm -rf /usr/share/nginx/html/*

# Copy compiled bundle from builder
COPY --from=builder /app/dist /usr/share/nginx/html

# Copy nginx config and strip Windows CRLF line endings (causes silent parse errors)
COPY nginx.conf /etc/nginx/conf.d/default.conf
RUN sed -i 's/\r//' /etc/nginx/conf.d/default.conf && nginx -t

EXPOSE 3000
CMD ["nginx", "-g", "daemon off;"]
